# Option 1: OpenAI (preferred when you have quota)
OPENAI_API_KEY="enter your openai api key here"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBED_MODEL="text-embedding-3-small"
#
# Option 2: Local LLM via Ollama (used only when OPENAI_API_KEY is not set)
# - Install Ollama from https://ollama.com, then: ollama pull llama3.1
USE_OLLAMA="1"
# If neither is available, the app runs in no-LLM mode (evidence-only summaries).